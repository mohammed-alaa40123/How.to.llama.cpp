{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mohammed-alaa40123.github.io/How.to.llama.cpp/schemas/retrospective-coding-batch.schema.json",
  "title": "How.to.llama.cpp retrospective coding batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_version", "source_revision", "sampling_frame", "records"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "protocol_version": {"const": "data01b-v0.1"},
    "source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sampling_frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_utc", "end_utc", "selection_rule", "excluded_run_ids"],
      "properties": {
        "start_utc": {"type": "string", "format": "date-time"},
        "end_utc": {"type": "string", "format": "date-time"},
        "selection_rule": {"enum": ["all_eligible_runs", "systematic_every_nth"]},
        "interval_n": {"type": "integer", "minimum": 2, "maximum": 100},
        "excluded_run_ids": {"type": "array", "maxItems": 1000, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run_id", "evidence_path", "assignment_outcome", "selection_path", "human_intervention", "validation_outcome", "evidence_completeness", "coder", "coding_status"],
        "properties": {
          "run_id": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{4}Z-[a-z0-9-]{3,64}$"},
          "evidence_path": {"type": "string"},
          "assignment_outcome": {"enum": ["completed", "partial", "blocked_reassigned", "blocked_stopped"]},
          "selection_path": {"enum": ["highest_priority_ready", "blocked_then_dependency_safe", "human_override", "historical_reconstruction"]},
          "human_intervention": {"enum": ["none_recorded", "approval", "correction", "merge_resolution", "environment_access", "ethics_or_privacy_decision", "not_reconstructable"]},
          "validation_outcome": {"enum": ["passed_first_attempt", "failed_then_fixed", "failed_unresolved", "not_run", "not_reconstructable"]},
          "evidence_completeness": {"enum": ["complete_for_protocol", "partial", "not_reconstructable"]},
          "missing_fields": {"type": "array", "maxItems": 30, "uniqueItems": true, "items": {"enum": ["tool_calls", "human_minutes", "api_cost", "failed_attempts", "ci_run", "output_decisions", "blocker_detail"]}},
          "coder": {"enum": ["agent_primary", "human_primary", "independent_reviewer"]},
          "coding_status": {"enum": ["single_coded", "double_coded_agree", "double_coded_disagree", "adjudicated"]},
          "disagreement_fields": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"type": "string"}},
          "adjudication_note": {"type": "string", "maxLength": 1200}
        }
      }
    }
  }
}
