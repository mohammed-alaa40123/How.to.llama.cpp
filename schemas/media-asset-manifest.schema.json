{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mohammed-alaa40123.github.io/How.to.llama.cpp/schemas/media-asset-manifest.schema.json",
  "title": "How.to.llama.cpp media asset manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_id",
    "asset_kind",
    "authority",
    "review_status",
    "publication",
    "source",
    "generation",
    "output",
    "accessibility",
    "licensing",
    "human_review"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "asset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"},
    "asset_kind": {"enum": ["diagram", "illustration", "audio", "video"]},
    "authority": {"enum": ["authoritative-technical", "supplemental"]},
    "review_status": {"enum": ["pending", "accepted", "revised", "rejected"]},
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publish"],
      "properties": {"publish": {"type": "boolean"}}
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "input_paths", "input_sha256"],
      "properties": {
        "repository": {"const": "mohammed-alaa40123/How.to.llama.cpp"},
        "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "input_paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 240}
        },
        "input_sha256": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "generator", "generator_version", "manual_trigger", "cached", "ordinary_ci_allowed"],
      "properties": {
        "mode": {"enum": ["deterministic", "human-authored", "generative-api"]},
        "generator": {"type": "string", "minLength": 1, "maxLength": 120},
        "generator_version": {"type": "string", "minLength": 1, "maxLength": 120},
        "model": {"type": ["string", "null"], "maxLength": 120},
        "prompt_path": {"type": ["string", "null"], "maxLength": 240},
        "prompt_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "storyboard_path": {"type": ["string", "null"], "maxLength": 240},
        "storyboard_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "manual_trigger": {"type": "boolean"},
        "cached": {"type": "boolean"},
        "ordinary_ci_allowed": {"type": "boolean"}
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mime_type", "sha256", "bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 240},
        "mime_type": {"enum": ["image/svg+xml", "image/png", "image/webp", "audio/mpeg", "audio/wav", "video/mp4", "text/vtt"]},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": "integer", "minimum": 1, "maximum": 536870912}
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alt_text", "caption_path", "transcript_path", "static_fallback_path", "reduced_motion_safe"],
      "properties": {
        "alt_text": {"type": "string", "minLength": 20, "maxLength": 2000},
        "caption_path": {"type": ["string", "null"], "maxLength": 240},
        "transcript_path": {"type": ["string", "null"], "maxLength": 240},
        "static_fallback_path": {"type": ["string", "null"], "maxLength": 240},
        "reduced_motion_safe": {"type": "boolean"}
      }
    },
    "technical_claims": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "evidence_kind"],
        "properties": {
          "claim": {"type": "string", "minLength": 10, "maxLength": 1000},
          "evidence_kind": {"enum": ["verified", "interpretation", "historical", "open-question"]}
        }
      }
    },
    "licensing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_license", "input_license_notes", "redistribution_allowed"],
      "properties": {
        "asset_license": {"type": "string", "minLength": 2, "maxLength": 120},
        "input_license_notes": {"type": "string", "minLength": 10, "maxLength": 2000},
        "redistribution_allowed": {"type": "boolean"}
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "approved", "reviewer_role", "reviewed_at", "notes"],
      "properties": {
        "required": {"type": "boolean"},
        "approved": {"type": "boolean"},
        "reviewer_role": {"type": ["string", "null"], "maxLength": 120},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
        "notes": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
