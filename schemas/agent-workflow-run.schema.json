{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mohammed-alaa40123.github.io/How.to.llama.cpp/schemas/agent-workflow-run.schema.json",
  "title": "How.to.llama.cpp retrospective agent workflow run",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "role", "assignment", "revisions", "outputs", "validation", "human_supervision", "effort", "claims"],
  "$defs": {
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence_paths"],
      "properties": {
        "status": {"enum": ["measured", "not_available", "not_applicable"]},
        "value": {"type": "number", "minimum": 0},
        "reason": {"type": "string", "minLength": 10, "maxLength": 500},
        "evidence_paths": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"type": "string", "minLength": 3, "maxLength": 300}}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "measured"}}, "required": ["status"]},
          "then": {"required": ["value"], "not": {"required": ["reason"]}, "properties": {"evidence_paths": {"minItems": 1}}},
          "else": {"required": ["reason"], "not": {"required": ["value"]}}
        }
      ]
    },
    "integerMeasurement": {
      "allOf": [
        {"$ref": "#/$defs/measurement"},
        {"properties": {"value": {"type": "integer", "minimum": 0}}}
      ]
    }
  },
  "properties": {
    "schema_version": {"enum": ["1.0.0", "1.1.0"]},
    "run_id": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{4}Z-[a-z0-9-]{3,64}$"},
    "role": {"enum": ["orchestrator", "documentation_builder", "validation_architect", "literature_scout", "adversarial_reviewer", "human_reviewer"]},
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "priority", "objective", "dependency_state", "selected_reason"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z0-9]+-[0-9]{2}$"},
        "priority": {"enum": ["P0", "P1", "P2", "P3"]},
        "objective": {"type": "string", "minLength": 20, "maxLength": 500},
        "dependency_state": {"enum": ["ready", "blocked", "in_progress"]},
        "selected_reason": {"type": "string", "minLength": 20, "maxLength": 800},
        "blocker": {"type": "string", "minLength": 10, "maxLength": 800}
      }
    },
    "revisions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["starting_commit", "ending_commit", "base_branch", "working_branch"],
      "properties": {
        "starting_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "ending_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "base_branch": {"type": "string", "minLength": 1, "maxLength": 128},
        "working_branch": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "outputs": {
      "type": "array", "minItems": 1, "maxItems": 50,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["path", "kind", "decision"],
        "properties": {
          "path": {"type": "string", "pattern": "^(docs|schemas|scripts|tests|labs|executable_lectures|trace_viewer|media|progress|logs|\\.github|\\.devcontainer)/[^\\\\]+$"},
          "kind": {"enum": ["documentation", "schema", "validator", "test", "fixture", "implementation", "run_log", "review_record", "ci_config"]},
          "decision": {"enum": ["accepted", "revised", "rejected"]},
          "reason": {"type": "string", "maxLength": 500}
        }
      }
    },
    "validation": {
      "type": "object", "additionalProperties": false,
      "required": ["validators", "failures", "ci_state"],
      "properties": {
        "validators": {"type": "array", "maxItems": 30, "uniqueItems": true, "items": {"type": "string", "minLength": 3, "maxLength": 200}},
        "failures": {
          "type": "array", "maxItems": 30,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["stage", "category", "resolution"],
            "properties": {
              "stage": {"type": "string", "minLength": 2, "maxLength": 100},
              "category": {"enum": ["dependency", "technical", "source_error", "test", "ci", "accessibility", "licensing", "privacy", "scope", "tooling"]},
              "resolution": {"enum": ["fixed", "deferred", "blocked", "not_reproducible"]},
              "summary": {"type": "string", "minLength": 10, "maxLength": 800}
            }
          }
        },
        "ci_state": {"enum": ["not_run", "queued", "in_progress", "passed", "failed"]},
        "ci_run_id": {"type": "integer", "minimum": 1}
      }
    },
    "human_supervision": {
      "type": "object", "additionalProperties": false,
      "required": ["required", "decisions", "review_status"],
      "properties": {
        "required": {"type": "boolean"},
        "decisions": {"type": "array", "maxItems": 20, "items": {"type": "string", "minLength": 10, "maxLength": 500}},
        "review_status": {"enum": ["not_required", "pending", "approved", "changes_requested", "rejected"]}
      }
    },
    "effort": {
      "oneOf": [
        {
          "title": "Legacy complete numeric effort record",
          "type": "object", "additionalProperties": false,
          "required": ["agent_turns", "tool_calls", "external_api_cost_usd", "paid_generation_calls"],
          "properties": {
            "agent_turns": {"type": "integer", "minimum": 1, "maximum": 100},
            "tool_calls": {"type": "integer", "minimum": 0, "maximum": 1000},
            "external_api_cost_usd": {"type": "number", "minimum": 0},
            "paid_generation_calls": {"type": "integer", "minimum": 0},
            "human_minutes": {"type": "integer", "minimum": 0, "maximum": 100000}
          }
        },
        {
          "title": "Explicit-status effort record",
          "type": "object", "additionalProperties": false,
          "required": ["agent_turns", "tool_calls", "external_api_cost_usd", "paid_generation_calls", "human_minutes"],
          "properties": {
            "agent_turns": {"$ref": "#/$defs/integerMeasurement"},
            "tool_calls": {"$ref": "#/$defs/integerMeasurement"},
            "external_api_cost_usd": {"$ref": "#/$defs/measurement"},
            "paid_generation_calls": {"$ref": "#/$defs/integerMeasurement"},
            "human_minutes": {"$ref": "#/$defs/integerMeasurement"}
          }
        }
      ]
    },
    "claims": {
      "type": "array", "minItems": 1, "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["label", "statement", "evidence_paths"],
        "properties": {
          "label": {"enum": ["Verified", "Interpretation", "Historical", "Open Question"]},
          "statement": {"type": "string", "minLength": 10, "maxLength": 800},
          "evidence_paths": {"type": "array", "maxItems": 20, "uniqueItems": true, "items": {"type": "string", "minLength": 3, "maxLength": 300}}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "1.0.0"}}},
      "then": {"properties": {"effort": {"type": "object", "properties": {"agent_turns": {"type": "integer"}}}}},
      "else": {"properties": {"effort": {"type": "object", "properties": {"agent_turns": {"type": "object"}}}}}
    }
  ]
}
