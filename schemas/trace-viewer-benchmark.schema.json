{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mohammed-alaa40123.github.io/How.to.llama.cpp/schemas/trace-viewer-benchmark.schema.json",
  "title": "Information-equivalent trace-viewer benchmark",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "source_revision",
    "trace_fixture",
    "conditions",
    "tasks",
    "scoring",
    "timing",
    "accessibility"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "benchmark_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
    "source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "trace_fixture": {"type": "string", "pattern": "^executable_lectures/traces/[A-Za-z0-9._/-]+\\.json$"},
    "conditions": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["condition_id", "presentation", "evidence_ids", "question_ids"],
        "properties": {
          "condition_id": {"enum": ["static-source-text", "interactive-viewer"]},
          "presentation": {"type": "string", "minLength": 20},
          "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "question_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "allowed_interface_features": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "task_type", "prompt", "answer_key", "evidence_ids", "points"],
        "properties": {
          "question_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
          "task_type": {"enum": ["code-tracing", "evidence-boundary", "transfer"]},
          "prompt": {"type": "string", "minLength": 20},
          "answer_key": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "points": {"type": "integer", "minimum": 1, "maximum": 10}
        }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "partial_credit", "missing_response_points", "reporting"],
      "properties": {
        "method": {"const": "frozen-exact-key"},
        "partial_credit": {"type": "boolean"},
        "missing_response_points": {"const": 0},
        "reporting": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clock", "limit_seconds", "timeout_handling"],
      "properties": {
        "clock": {"const": "monotonic"},
        "limit_seconds": {"type": "integer", "minimum": 60, "maximum": 1800},
        "timeout_handling": {"const": "retain-responses-and-report-timeout-separately"}
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyboard", "static_fallback", "reduced_motion", "screen_reader_text"],
      "properties": {
        "keyboard": {"const": true},
        "static_fallback": {"const": true},
        "reduced_motion": {"const": true},
        "screen_reader_text": {"const": true}
      }
    }
  }
}
