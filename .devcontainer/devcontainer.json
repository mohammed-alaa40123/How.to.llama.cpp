{
  "name": "How.to.llama.cpp executable learning",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "UV_VERSION": "0.8.0"
    }
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python"
      ]
    }
  }
}
